#!/usr/bin/env python3
"""
engram — Persistent memory CLI for Claude Code
~/.claude/engram/engram

SQLite + FTS5 knowledge base with cross-machine git sync.

Usage:
  engram search "query"                  # search all notes (~50 tokens)
  engram search -p . "query"             # search current project
  engram get <id>                        # fetch full note
  engram add "Title" "tags" "body"       # add global note
  engram add -p . "Title" "tags" "body"  # add project note
  engram list                            # recent notes
  engram list -p .                       # project notes
  engram tags                            # all tags + counts
  engram topics                          # topic hub notes
  engram stats                           # db stats + sync info
  engram session start                   # begin session log
  engram session end                     # archive session
  engram session recent                  # show recent sessions
  engram ingest <file>                   # curation protocol for a file
  engram update <id> "new content"       # update a note's content
  engram archive <id>                    # soft-delete note
  engram unarchive <id>                  # reverse a soft-delete
  engram purge [--older-than N]          # hard-delete archived notes (default: 90 days)
  engram export                          # dump to JSON (stdout)
  engram import <file>                   # restore from JSON
  engram rebuild-fts                     # rebuild full-text search index
  engram doctor                          # health check: FTS, UUIDs, sync status

  engram remote add <url>                # configure git sync remote
  engram remote show                     # show current remote
  engram push                            # export → commit → push
  engram pull                            # pull → merge new notes
  engram sync                            # pull then push (full sync)
"""

import sys
import os
import json
import sqlite3
import datetime
import argparse
import subprocess
import uuid as _uuid
from pathlib import Path

ENGRAM_DIR   = Path.home() / ".claude" / "engram"
DB_PATH      = ENGRAM_DIR / "memory.db"
SESSION_PATH = ENGRAM_DIR / ".current_session.json"
CONFIG_PATH  = ENGRAM_DIR / "config.json"
SYNC_DIR     = ENGRAM_DIR / "sync"
SYNC_FILE    = SYNC_DIR / "memory.json"

# Whitelist of columns allowed in import/pull to prevent SQL injection
ALLOWED_COLUMNS = frozenset({
    'uuid', 'type', 'project', 'title', 'tags', 'content',
    'summary', 'machine', 'created_at', 'updated_at', 'archived_at'
})

# ─── CONFIG ───────────────────────────────────────────────────────────────────

def load_config() -> dict:
    if CONFIG_PATH.exists():
        return json.loads(CONFIG_PATH.read_text())
    return {}

def save_config(cfg: dict):
    ENGRAM_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2))

def machine_name() -> str:
    return load_config().get("machine", os.uname().nodename)

# ─── DB ───────────────────────────────────────────────────────────────────────

SCHEMA = """
CREATE TABLE IF NOT EXISTS notes (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    uuid        TEXT    UNIQUE,
    type        TEXT    NOT NULL DEFAULT 'note',
    project     TEXT    DEFAULT NULL,
    title       TEXT    NOT NULL,
    tags        TEXT    NOT NULL DEFAULT '',
    content     TEXT    NOT NULL,
    summary     TEXT    NOT NULL DEFAULT '',
    machine     TEXT    DEFAULT NULL,
    created_at  TEXT    DEFAULT (datetime('now')),
    updated_at  TEXT    DEFAULT (datetime('now')),
    archived_at TEXT    DEFAULT NULL
);
CREATE INDEX IF NOT EXISTS idx_notes_project ON notes(project);
CREATE INDEX IF NOT EXISTS idx_notes_type    ON notes(type);
CREATE INDEX IF NOT EXISTS idx_notes_tags    ON notes(tags);
CREATE INDEX IF NOT EXISTS idx_notes_uuid    ON notes(uuid);
CREATE VIRTUAL TABLE IF NOT EXISTS notes_fts USING fts5(
    title, tags, content, summary, project,
    content='notes', content_rowid='id'
);
CREATE TRIGGER IF NOT EXISTS notes_ai AFTER INSERT ON notes BEGIN
    INSERT INTO notes_fts(rowid, title, tags, content, summary, project)
    VALUES (new.id, new.title, new.tags, new.content, new.summary, new.project);
END;
CREATE TRIGGER IF NOT EXISTS notes_ad AFTER DELETE ON notes BEGIN
    INSERT INTO notes_fts(notes_fts, rowid, title, tags, content, summary, project)
    VALUES ('delete', old.id, old.title, old.tags, old.content, old.summary, old.project);
END;
CREATE TRIGGER IF NOT EXISTS notes_au AFTER UPDATE ON notes BEGIN
    INSERT INTO notes_fts(notes_fts, rowid, title, tags, content, summary, project)
    VALUES ('delete', old.id, old.title, old.tags, old.content, old.summary, old.project);
    INSERT INTO notes_fts(rowid, title, tags, content, summary, project)
    VALUES (new.id, new.title, new.tags, new.content, new.summary, new.project);
END;
"""

def get_db():
    ENGRAM_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    # Migrate first — add new columns before running SCHEMA (which may reference them)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS notes (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            type        TEXT    NOT NULL DEFAULT 'note',
            project     TEXT    DEFAULT NULL,
            title       TEXT    NOT NULL,
            tags        TEXT    NOT NULL DEFAULT '',
            content     TEXT    NOT NULL,
            summary     TEXT    NOT NULL DEFAULT '',
            created_at  TEXT    DEFAULT (datetime('now')),
            updated_at  TEXT    DEFAULT (datetime('now')),
            archived_at TEXT    DEFAULT NULL
        )
    """)
    conn.commit()
    cols = [r[1] for r in conn.execute("PRAGMA table_info(notes)").fetchall()]
    if 'uuid' not in cols:
        conn.execute("ALTER TABLE notes ADD COLUMN uuid TEXT")
        conn.commit()
    if 'machine' not in cols:
        conn.execute("ALTER TABLE notes ADD COLUMN machine TEXT")
        conn.commit()
    # Backfill updated_at=created_at for rows that predate the column —
    # prevents remote pull from silently overwriting them on first sync
    conn.execute("UPDATE notes SET updated_at=created_at WHERE updated_at IS NULL")
    conn.commit()
    # Now run full schema (indexes, FTS, triggers)
    conn.executescript(SCHEMA)
    conn.commit()
    return conn

def make_uuid() -> str:
    return _uuid.uuid4().hex[:16]

def ensure_uuids(db):
    rows = db.execute("SELECT id FROM notes WHERE uuid IS NULL").fetchall()
    for r in rows:
        db.execute("UPDATE notes SET uuid=? WHERE id=?", [make_uuid(), r['id']])
    if rows:
        db.commit()

def make_summary(content: str, length=180) -> str:
    text = " ".join(content.split())
    return text[:length] + ("…" if len(text) > length else "")

def fmt_date(dt_str: str) -> str:
    try:
        return datetime.datetime.fromisoformat(dt_str).strftime("%Y-%m-%d")
    except Exception:
        return dt_str or ""

def safe_insert(db, row: dict):
    """Insert a row using only whitelisted columns (prevents SQL injection)."""
    filtered = {k: v for k, v in row.items() if k in ALLOWED_COLUMNS}
    filtered.pop('id', None)
    if not filtered:
        return None
    cols = ', '.join(filtered.keys())
    placeholders = ', '.join(['?'] * len(filtered))
    return db.execute(
        f"INSERT OR IGNORE INTO notes ({cols}) VALUES ({placeholders})",
        list(filtered.values())
    )

# ─── CORE COMMANDS ────────────────────────────────────────────────────────────

def cmd_search(args):
    project = resolve_project(args)
    db = get_db()
    where_extra = "AND n.archived_at IS NULL AND n.type != 'session'"
    params = [args.query]
    if project:
        where_extra += " AND (n.project = ? OR n.project IS NULL)"
        params.append(project)
    sql = f"""
        SELECT n.id, n.type, n.project, n.title, n.tags, n.summary, n.machine
        FROM notes_fts f JOIN notes n ON f.rowid = n.id
        WHERE notes_fts MATCH ? {where_extra}
        ORDER BY rank LIMIT 10
    """
    # FTS crash safety — fall back to LIKE on bad query syntax
    try:
        rows = db.execute(sql, params).fetchall()
    except sqlite3.OperationalError:
        like = f"%{args.query}%"
        like_params = [like, like, like]
        extra = ""
        if project:
            extra = " AND (project = ? OR project IS NULL)"
            like_params.append(project)
        rows = db.execute(
            f"SELECT id, type, project, title, tags, summary, machine FROM notes "
            f"WHERE archived_at IS NULL AND type != 'session' "
            f"AND (title LIKE ? OR content LIKE ? OR summary LIKE ?){extra} LIMIT 10",
            like_params
        ).fetchall()
    if not rows:
        print("No results.")
        return
    for r in rows:
        proj  = f"[{r['project']}] " if r['project'] else ""
        tags  = f"  #{r['tags']}" if r['tags'] else ""
        badge = f"({r['type']}) " if r['type'] != 'note' else ""
        mach  = f" @{r['machine']}" if r['machine'] and r['machine'] != machine_name() else ""
        print(f"[{r['id']:04d}] {badge}{proj}{r['title']}{tags}{mach}")
        if r['summary']:
            print(f"       {r['summary'][:120]}")
        print()

def cmd_get(args):
    db = get_db()
    row = db.execute("SELECT * FROM notes WHERE id = ?", [args.id]).fetchone()
    if not row:
        print(f"Note {args.id} not found.")
        return
    proj = f"  project: {row['project']}" if row['project'] else ""
    mach = f"  machine: {row['machine']}" if row['machine'] else ""
    print(f"─── [{row['id']:04d}] {row['title']} ───")
    print(f"  type: {row['type']}  tags: {row['tags']}{proj}{mach}")
    print(f"  created: {fmt_date(row['created_at'])}  updated: {fmt_date(row['updated_at'])}")
    if row['archived_at']:
        print(f"  ⚠ ARCHIVED: {fmt_date(row['archived_at'])}")
    print()
    print(row['content'])
    print()

def cmd_add(args):
    project = resolve_project(args)
    content = args.body
    db = get_db()
    cursor = db.execute(
        "INSERT INTO notes (uuid, type, project, title, tags, content, summary, machine) VALUES (?,?,?,?,?,?,?,?)",
        [make_uuid(), 'note', project, args.title, args.tags, content, make_summary(content), machine_name()]
    )
    db.commit()
    scope = f"[{project}]" if project else "[global]"
    print(f"✓ Added note {cursor.lastrowid:04d} {scope}: {args.title}")

def cmd_list(args):
    project = resolve_project(args)
    db = get_db()
    limit = getattr(args, 'limit', 15)
    where = "WHERE archived_at IS NULL AND type = 'note'"
    params = []
    if project:
        where += " AND project = ?"
        params.append(project)
    rows = db.execute(
        f"SELECT id, project, title, tags, summary, created_at FROM notes {where} ORDER BY id DESC LIMIT ?",
        params + [limit]
    ).fetchall()
    if not rows:
        print("No notes found.")
        return
    for r in rows:
        proj = f"[{r['project']}] " if r['project'] else ""
        tags = f"  #{r['tags']}" if r['tags'] else ""
        print(f"[{r['id']:04d}] {proj}{r['title']}{tags}  ({fmt_date(r['created_at'])})")
        if r['summary']:
            print(f"       {r['summary'][:100]}")
    print(f"\n{len(rows)} notes shown.")

def cmd_tags(args):
    db = get_db()
    rows = db.execute("SELECT tags FROM notes WHERE archived_at IS NULL AND tags != ''").fetchall()
    counts = {}
    for r in rows:
        for tag in r['tags'].split(','):
            tag = tag.strip()
            if tag:
                counts[tag] = counts.get(tag, 0) + 1
    if not counts:
        print("No tags found.")
        return
    for tag, count in sorted(counts.items(), key=lambda x: -x[1]):
        print(f"  {tag:<30} {count}")

def cmd_topics(args):
    db = get_db()
    rows = db.execute(
        "SELECT id, title, summary FROM notes WHERE type='topic' AND archived_at IS NULL ORDER BY title"
    ).fetchall()
    if not rows:
        print("No topic notes yet.")
        print("  Create one: engram add \"Topic: <Name>\" \"topic-note,<tag>\" \"Hub for <concept>...\"")
        return
    print("── Topic Hubs ──")
    for r in rows:
        print(f"[{r['id']:04d}] {r['title']}")
        if r['summary']:
            print(f"       {r['summary'][:100]}")
    print()

def cmd_stats(args):
    db = get_db()
    total    = db.execute("SELECT COUNT(*) FROM notes WHERE archived_at IS NULL").fetchone()[0]
    sessions = db.execute("SELECT COUNT(*) FROM notes WHERE type='session' AND archived_at IS NULL").fetchone()[0]
    compacts = db.execute("SELECT COUNT(*) FROM notes WHERE type='compact' AND archived_at IS NULL").fetchone()[0]
    topics   = db.execute("SELECT COUNT(*) FROM notes WHERE type='topic'   AND archived_at IS NULL").fetchone()[0]
    archived = db.execute("SELECT COUNT(*) FROM notes WHERE archived_at IS NOT NULL").fetchone()[0]
    projects = db.execute("SELECT COUNT(DISTINCT project) FROM notes WHERE project IS NOT NULL AND archived_at IS NULL").fetchone()[0]
    size_kb  = DB_PATH.stat().st_size // 1024 if DB_PATH.exists() else 0
    cfg      = load_config()
    print(f"── engram stats ────────────────────")
    print(f"  Machine:           {cfg.get('machine', os.uname().nodename)}")
    print(f"  Notes (active):    {total - sessions - compacts - topics}")
    print(f"  Session logs:      {sessions}")
    print(f"  Compact summaries: {compacts}")
    print(f"  Topic hubs:        {topics}")
    print(f"  Archived:          {archived}")
    print(f"  Projects tracked:  {projects}")
    print(f"  DB size:           {size_kb} KB")
    print(f"  DB path:           {DB_PATH}")
    print(f"  Sync remote:       {cfg.get('remote', 'not configured')}")

def cmd_update(args):
    db = get_db()
    row = db.execute("SELECT id, title FROM notes WHERE id = ?", [args.id]).fetchone()
    if not row:
        print(f"Note {args.id} not found.")
        return
    db.execute(
        "UPDATE notes SET content=?, summary=?, updated_at=datetime('now') WHERE id=?",
        [args.content, make_summary(args.content), args.id]
    )
    db.commit()
    print(f"✓ Note {args.id} updated: {row['title']}")

def cmd_archive(args):
    db = get_db()
    cursor = db.execute(
        "UPDATE notes SET archived_at=datetime('now') WHERE id=? AND archived_at IS NULL",
        [args.id]
    )
    db.commit()
    if cursor.rowcount:
        print(f"✓ Note {args.id} archived.")
    else:
        print(f"Note {args.id} not found or already archived.")

def cmd_unarchive(args):
    db = get_db()
    cursor = db.execute(
        "UPDATE notes SET archived_at=NULL WHERE id=? AND archived_at IS NOT NULL",
        [args.id]
    )
    db.commit()
    if cursor.rowcount:
        print(f"✓ Note {args.id} unarchived.")
    else:
        print(f"Note {args.id} not found or not archived.")

def cmd_purge(args):
    days = args.days
    cutoff = (datetime.datetime.now() - datetime.timedelta(days=days)).isoformat()
    db = get_db()
    count = db.execute(
        "SELECT COUNT(*) FROM notes WHERE archived_at IS NOT NULL AND archived_at < ?",
        [cutoff]
    ).fetchone()[0]
    if count == 0:
        print(f"No archived notes older than {days} days.")
        return
    answer = input(f"Permanently delete {count} archived note(s)? [y/N] ")
    if answer.lower() != 'y':
        print("Aborted.")
        return
    cursor = db.execute(
        "DELETE FROM notes WHERE archived_at IS NOT NULL AND archived_at < ?",
        [cutoff]
    )
    db.commit()
    print(f"✓ Purged {cursor.rowcount} archived notes older than {days} days.")

def cmd_export(args):
    db = get_db()
    ensure_uuids(db)
    rows = db.execute("SELECT * FROM notes").fetchall()
    print(json.dumps([dict(r) for r in rows], indent=2))

def cmd_import(args):
    with open(args.file) as f:
        data = json.load(f)
    if not isinstance(data, list):
        print("✗ Import file must be a JSON array.")
        return
    db = get_db()
    inserted = skipped = 0
    for r in data:
        if not isinstance(r, dict):
            skipped += 1
            continue
        cursor = safe_insert(db, r)
        if cursor and cursor.rowcount:
            inserted += 1
        else:
            skipped += 1
    db.commit()
    print(f"✓ Imported {inserted} notes ({skipped} duplicates/invalid skipped).")

def cmd_ingest(args):
    print(f"""
── engram ingest: Curation Protocol ───────────────────────────────────────

File to analyse: {args.file}

Instructions for Claude Code:
1. Read the file carefully
2. Extract ONLY non-obvious, high-value insights — not obvious docs content
3. For each insight, call:
   engram add "Concise title" "tag1,tag2" "Atomic content — context, insight, gotcha"
4. Use -p <project_name> if this knowledge is project-specific
5. Skip anything easily found in official docs or that you already know
6. Aim for 5–15 notes max per document — quality over quantity

Quality checklist:
  ✓ Actionable — tells you WHAT TO DO, not just what exists
  ✓ Contextual — explains WHEN this applies
  ✓ Non-obvious — captures what docs don't make clear
  ✓ Distilled — your words, not copy-paste

Begin analysis of: {args.file}
""")

def cmd_rebuild_fts(args):
    db = get_db()
    # FTS5 'rebuild' re-reads all rows from the content table and rebuilds the index
    db.execute("INSERT INTO notes_fts(notes_fts) VALUES('rebuild')")
    db.commit()
    count = db.execute("SELECT COUNT(*) FROM notes").fetchone()[0]
    print(f"✓ FTS index rebuilt ({count} notes indexed).")

def cmd_doctor(args):
    db = get_db()

    total    = db.execute("SELECT COUNT(*) FROM notes").fetchone()[0]
    active   = db.execute("SELECT COUNT(*) FROM notes WHERE archived_at IS NULL").fetchone()[0]
    archived = total - active

    # FTS row count
    try:
        fts_count = db.execute("SELECT COUNT(*) FROM notes_fts").fetchone()[0]
    except sqlite3.OperationalError:
        fts_count = -1

    # Duplicate UUIDs
    dupes = db.execute(
        "SELECT uuid, COUNT(*) c FROM notes WHERE uuid IS NOT NULL GROUP BY uuid HAVING c > 1"
    ).fetchall()

    # NULL UUIDs — check before backfill so we can report accurately
    null_uuids = db.execute("SELECT COUNT(*) FROM notes WHERE uuid IS NULL").fetchone()[0]

    # NULL updated_at
    null_updated = db.execute("SELECT COUNT(*) FROM notes WHERE updated_at IS NULL").fetchone()[0]

    cfg     = load_config()
    remote  = cfg.get('remote')
    sync_ok = SYNC_DIR.exists() and (SYNC_DIR / ".git").exists()

    print("── engram doctor ──────────────────────────────────────")
    print(f"  Notes total:    {total}  (active: {active}, archived: {archived})")

    issues = 0

    # FTS check — FTS indexes all rows (including archived), so compare against total
    if fts_count == -1:
        print(f"  ✗ FTS table missing — run: engram rebuild-fts")
        issues += 1
    elif fts_count != total:
        print(f"  ✗ FTS mismatch: {total} notes, {fts_count} FTS rows — run: engram rebuild-fts")
        issues += 1
    else:
        print(f"  ✓ FTS index consistent ({fts_count} rows)")

    # UUID checks
    if dupes:
        print(f"  ✗ Duplicate UUIDs: {len(dupes)} — manual inspection needed")
        for d in dupes:
            print(f"      uuid={d['uuid']} appears {d['c']} times")
        issues += 1
    else:
        print(f"  ✓ No duplicate UUIDs")

    if null_uuids > 0:
        print(f"  ⚠ {null_uuids} note(s) have NULL uuid — running backfill...")
        ensure_uuids(db)
        print(f"    ✓ Backfilled {null_uuids} uuid(s).")
    else:
        print(f"  ✓ All notes have UUIDs")

    if null_updated:
        print(f"  ✗ Notes missing updated_at: {null_updated}")
        issues += 1
    else:
        print(f"  ✓ All timestamps populated")

    # Sync check
    if not remote:
        print(f"  ⚠ No sync remote — run: engram remote add <url>")
    elif not sync_ok:
        print(f"  ⚠ Remote configured but not cloned — run: engram pull")
        issues += 1
    else:
        print(f"  ✓ Sync remote: {remote}")

    # Hook log
    log_path = ENGRAM_DIR / "hook.log"
    if log_path.exists():
        size = log_path.stat().st_size
        print(f"  ✓ hook.log exists ({size // 1024} KB) — tail: tail -f {log_path}")
    else:
        print(f"  ⚠ hook.log missing — run install.sh or: touch {log_path}")

    print()
    if issues == 0:
        print("  ✓ All checks passed.")
    else:
        print(f"  {issues} issue(s) found.")

# ─── SESSION COMMANDS ─────────────────────────────────────────────────────────

def cmd_session_start(args):
    project = resolve_project(args)
    cwd = os.getcwd()
    now = datetime.datetime.now().isoformat()
    # Use session_id (not pid) for consistency with the hook's session identity
    session = {
        "started_at": now,
        "project": project or Path(cwd).name,
        "cwd": cwd,
        "session_id": make_uuid(),
    }
    SESSION_PATH.write_text(json.dumps(session, indent=2))
    print(f"✓ Session started at {now[:16].replace('T',' ')}")
    print(f"  Project: {session['project']}  |  Machine: {machine_name()}")
    db = get_db()
    recent = db.execute(
        "SELECT id, title, summary, created_at, machine FROM notes "
        "WHERE type IN ('session', 'compact') AND archived_at IS NULL ORDER BY id DESC LIMIT 5"
    ).fetchall()
    if recent:
        print("\n── Recent sessions (memory context) ────────────────────")
        for r in recent:
            mach = f" @{r['machine']}" if r['machine'] else ""
            print(f"  [{r['id']:04d}] {fmt_date(r['created_at'])}{mach}  {r['title']}")
            if r['summary']:
                print(f"         {r['summary'][:100]}")
        print()

def cmd_session_end(args):
    if not SESSION_PATH.exists():
        print("No active session. Run: engram session start")
        return
    session = json.loads(SESSION_PATH.read_text())

    started_str = session.get('started_at', '')
    started_dt  = datetime.datetime.fromisoformat(started_str)
    ended_dt    = datetime.datetime.now()
    duration_m  = (ended_dt - started_dt).total_seconds() / 60

    # Skip trivial sessions
    if duration_m < 5:
        SESSION_PATH.unlink(missing_ok=True)
        print(f"Session too short ({duration_m:.1f}min), not logged.")
        return

    project = session.get('project')
    started = started_str[:16].replace('T', ' ')
    ended   = ended_dt.isoformat()[:16].replace('T', ' ')

    what_done  = getattr(args, 'summary',    None) or "[Claude: fill in what was accomplished]"
    decisions  = getattr(args, 'decisions',  None) or "[Claude: fill in key decisions and rationale]"
    next_steps = getattr(args, 'next_steps', None) or "[Claude: fill in what to pick up next time]"
    files      = getattr(args, 'files',      None) or "[Claude: list key files modified]"
    context    = getattr(args, 'context',    None) or "[Claude: anything future-you needs to know]"

    content = f"""## Session: {started} → {ended}
Project: {project}
Machine: {machine_name()}
Dir: {session.get('cwd', '')}
Duration: {duration_m:.0f}min

### What Was Done
{what_done}

### Decisions Made
{decisions}

### Files Changed
{files}

### Next Steps
{next_steps}

### Context Notes
{context}
"""
    title = f"Session: {project} ({started[:10]})"
    db = get_db()
    cursor = db.execute(
        "INSERT INTO notes (uuid, type, project, title, tags, content, summary, machine) VALUES (?,?,?,?,?,?,?,?)",
        [make_uuid(), 'session', project, title, f'session,{project}', content, make_summary(content), machine_name()]
    )
    db.commit()
    SESSION_PATH.unlink(missing_ok=True)
    nid = cursor.lastrowid
    print(f"✓ Session logged as note {nid:04d}")
    print(f"  View:   engram get {nid}")
    if "[Claude:" in content:
        print(f"  Update: engram update {nid} \"<full content>\"  (fill in the empty sections)")

def cmd_session_recent(args):
    db = get_db()
    limit = getattr(args, 'limit', 10)
    rows = db.execute(
        "SELECT id, project, title, summary, created_at, machine FROM notes "
        "WHERE type IN ('session', 'compact') AND archived_at IS NULL ORDER BY id DESC LIMIT ?",
        [limit]
    ).fetchall()
    if not rows:
        print("No session logs yet.")
        return
    print("── Recent Sessions ──────────────────────────────────────")
    for r in rows:
        mach = f" @{r['machine']}" if r['machine'] else ""
        print(f"[{r['id']:04d}] {fmt_date(r['created_at'])}{mach}  [{r['project'] or 'global'}]  {r['title']}")
        if r['summary']:
            print(f"       {r['summary'][:110]}")
    print()

# ─── SYNC COMMANDS ────────────────────────────────────────────────────────────

def git(*cmd, cwd=None):
    result = subprocess.run(
        ["git"] + list(cmd),
        cwd=str(cwd or SYNC_DIR),
        capture_output=True, text=True
    )
    return result.stdout.strip(), result.returncode

def require_remote():
    remote = load_config().get("remote")
    if not remote:
        print("✗ No sync remote configured.")
        print("  Run: engram remote add git@github.com:<user>/engram-memory.git")
        sys.exit(1)
    return remote

def ensure_sync_clone(remote: str):
    if not SYNC_DIR.exists():
        print(f"  Cloning {remote}...")
        result = subprocess.run(
            ["git", "clone", remote, str(SYNC_DIR)],
            capture_output=True, text=True
        )
        if result.returncode != 0:
            print(f"✗ Clone failed:\n{result.stderr}")
            print("  Check your SSH key is added to GitHub (ssh -T git@github.com)")
            sys.exit(1)
        print(f"  ✓ Cloned to {SYNC_DIR}")

def cmd_remote_add(args):
    cfg = load_config()
    cfg["remote"] = args.url
    if not cfg.get("machine"):
        cfg["machine"] = os.uname().nodename
    save_config(cfg)
    print(f"✓ Remote set: {args.url}")
    print(f"  Machine name: {cfg['machine']}")
    print(f"\n  Next: engram push")

def cmd_remote_show(args):
    cfg = load_config()
    print(f"  Remote:  {cfg.get('remote', 'not configured')}")
    print(f"  Machine: {cfg.get('machine', os.uname().nodename)}")

def cmd_push(args):
    remote = require_remote()
    ensure_sync_clone(remote)
    db = get_db()
    ensure_uuids(db)

    print("── engram push ──────────────────────────────────────────")
    print("  Pulling latest first...")
    _, pull_rc = git("pull", "--rebase")
    if pull_rc != 0:
        print("✗ Pull failed before push — aborting to avoid overwriting remote changes.")
        print("  Fix the sync repo manually, then retry.")
        sys.exit(1)

    rows = db.execute("SELECT * FROM notes").fetchall()
    data = [dict(r) for r in rows]
    SYNC_FILE.write_text(json.dumps(data, indent=2))
    print(f"  Exported {len(data)} notes → memory.json")

    git("add", "memory.json")
    _, rc = git("diff", "--cached", "--quiet")
    if rc == 0:
        print("  Nothing new to push.")
        return

    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    msg = f"sync: {machine_name()} @ {now} ({len(data)} notes)"
    git("commit", "-m", msg)
    _, push_rc = git("push")
    if push_rc != 0:
        _, push_rc = git("push", "--set-upstream", "origin", "main")
    if push_rc == 0:
        print(f"  ✓ Pushed: {msg}")
    else:
        print(f"✗ Push failed. Check your SSH key and remote: engram remote show")

def cmd_pull(args):
    remote = require_remote()
    ensure_sync_clone(remote)

    print("── engram pull ──────────────────────────────────────────")
    print("  Pulling from remote...")
    _, rc = git("pull", "--rebase")
    if rc != 0:
        print("✗ Pull failed. Check your connection and SSH key.")
        sys.exit(1)

    if not SYNC_FILE.exists():
        print("  No memory.json in remote yet. Push from another machine first.")
        return

    remote_data = json.loads(SYNC_FILE.read_text())
    db = get_db()
    ensure_uuids(db)

    new_count = updated_count = 0
    for r in remote_data:
        uid = r.get("uuid")
        if not uid:
            continue
        local = db.execute("SELECT id, updated_at FROM notes WHERE uuid=?", [uid]).fetchone()
        if not local:
            safe_insert(db, r)
            new_count += 1
        else:
            remote_updated = r.get("updated_at", "")
            if remote_updated > (local["updated_at"] or ""):
                db.execute(
                    "UPDATE notes SET title=?, content=?, summary=?, tags=?, "
                    "archived_at=?, updated_at=? WHERE uuid=?",
                    [r.get("title"), r.get("content"), r.get("summary"),
                     r.get("tags"), r.get("archived_at"), remote_updated, uid]
                )
                updated_count += 1
    db.commit()

    if new_count or updated_count:
        print(f"  ✓ {new_count} new notes, {updated_count} updated from remote.")
    else:
        print(f"  Already up to date. ({len(remote_data)} notes in remote)")

def cmd_sync(args):
    cmd_pull(args)
    print()
    cmd_push(args)

# ─── HELPERS ──────────────────────────────────────────────────────────────────

def resolve_project(args):
    """
    Resolve project identity. Priority:
    1. Explicit -p <name> argument
    2. Git root folder name (avoids subdir collisions like src/, app/)
    3. Current directory name (fallback for non-git dirs)

    Note: git-remote-based identity (owner/repo) is the correct long-term
    approach for cross-machine stability, but requires a data migration since
    existing notes are stored by folder name. Tracked for a future release.
    """
    if hasattr(args, 'project'):
        p = args.project
        if p and p != '.':
            return Path(p).name if Path(p).is_absolute() else p
        try:
            result = subprocess.run(
                ['git', 'rev-parse', '--show-toplevel'],
                capture_output=True, text=True, cwd=os.getcwd()
            )
            if result.returncode == 0:
                return Path(result.stdout.strip()).name
        except Exception:
            pass
        return Path(os.getcwd()).name
    return None

# ─── CLI PARSER ───────────────────────────────────────────────────────────────

def build_parser():
    p = argparse.ArgumentParser(prog='engram', description='engram — persistent memory for Claude Code')
    sub = p.add_subparsers(dest='cmd')

    ps = sub.add_parser('search'); ps.add_argument('-p','--project',default=None,metavar='PROJECT'); ps.add_argument('query')
    pg = sub.add_parser('get');    pg.add_argument('id', type=int)
    pa = sub.add_parser('add');    pa.add_argument('-p','--project',default=None,metavar='PROJECT'); pa.add_argument('title'); pa.add_argument('tags'); pa.add_argument('body')
    pl = sub.add_parser('list');   pl.add_argument('-p','--project',default=None,metavar='PROJECT'); pl.add_argument('--limit',type=int,default=15)

    sub.add_parser('tags'); sub.add_parser('topics'); sub.add_parser('stats')

    pu = sub.add_parser('update'); pu.add_argument('id', type=int); pu.add_argument('content')
    par = sub.add_parser('archive');   par.add_argument('id', type=int)
    pun = sub.add_parser('unarchive'); pun.add_argument('id', type=int)
    ppu = sub.add_parser('purge');     ppu.add_argument('--older-than', type=int, default=90, dest='days')
    sub.add_parser('export')
    pi = sub.add_parser('import'); pi.add_argument('file')
    pin = sub.add_parser('ingest'); pin.add_argument('file')
    sub.add_parser('rebuild-fts')
    sub.add_parser('doctor')

    psess = sub.add_parser('session')
    psess_sub = psess.add_subparsers(dest='session_cmd')
    pss = psess_sub.add_parser('start'); pss.add_argument('-p','--project',default=None,metavar='PROJECT'); pss.add_argument('--goal',default=None)
    pse = psess_sub.add_parser('end');   pse.add_argument('--summary',default=None); pse.add_argument('--decisions',default=None); pse.add_argument('--next-steps',default=None); pse.add_argument('--files',default=None); pse.add_argument('--context',default=None)
    psr = psess_sub.add_parser('recent'); psr.add_argument('--limit',type=int,default=10)

    premote = sub.add_parser('remote')
    premote_sub = premote.add_subparsers(dest='remote_cmd')
    pra = premote_sub.add_parser('add'); pra.add_argument('url')
    premote_sub.add_parser('show')

    sub.add_parser('push')
    sub.add_parser('pull')
    sub.add_parser('sync')

    return p

def main():
    parser = build_parser()
    args = parser.parse_args()

    dispatch = {
        'search': cmd_search, 'get': cmd_get, 'add': cmd_add, 'list': cmd_list,
        'tags': cmd_tags, 'topics': cmd_topics, 'stats': cmd_stats,
        'update': cmd_update, 'archive': cmd_archive, 'unarchive': cmd_unarchive,
        'purge': cmd_purge, 'export': cmd_export, 'import': cmd_import,
        'ingest': cmd_ingest, 'rebuild-fts': cmd_rebuild_fts, 'doctor': cmd_doctor,
        'push': cmd_push, 'pull': cmd_pull, 'sync': cmd_sync,
    }

    if args.cmd == 'session':
        {'start': cmd_session_start, 'end': cmd_session_end, 'recent': cmd_session_recent}.get(
            args.session_cmd, lambda _: print("Usage: engram session [start|end|recent]")
        )(args)
    elif args.cmd == 'remote':
        {'add': cmd_remote_add, 'show': cmd_remote_show}.get(
            args.remote_cmd, lambda _: print("Usage: engram remote [add <url>|show]")
        )(args)
    elif args.cmd in dispatch:
        dispatch[args.cmd](args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
